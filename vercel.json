{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm ci --ignore-scripts --no-audit --no-fund",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://120.48.178.14:3501/api/:path*"
    },
    {
      "source": "/library/:path*",
      "destination": "http://120.48.178.14:3501/library/:path*"
    }
  ]
}
