{
  "name": "magical-canvas",
  "private": true,
  "version": "1.0.0",
  "description": "Magical Canvas 魔法画布 - AI 创作画布与视频剪辑工作室桌面应用",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/size0/canvas.git"
  },
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"vite\"",
    "server": "node server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "cross-env NODE_ENV=production electron .",
    "dist": "vite build && electron-builder --win portable",
    "test:screenplay": "node scripts/test-screenplay-quality.mjs",
    "setup:local-models": "node -e \"require('child_process').execSync(process.platform === 'win32' ? 'setup-local-models.bat' : 'bash setup-local-models.sh', {stdio: 'inherit'})\""
  },
  "dependencies": {
    "@fal-ai/client": "^1.8.0",
    "@google/genai": "^1.32.0",
    "@langchain/core": "^1.1.4",
    "@langchain/google-genai": "^2.0.4",
    "@langchain/langgraph": "^1.0.4",
    "@lobehub/icons": "^3.0.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@types/three": "^0.182.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "face-api.js": "^0.22.2",
    "ffmpeg-static": "^5.3.0",
    "form-data": "^4.0.5",
    "jsonrepair": "^3.15.0",
    "lucide-react": "^0.556.0",
    "msedge-tts": "^2.0.5",
    "openai": "^6.14.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "three": "^0.182.0",
    "twitter-api-v2": "^1.28.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "puppeteer-core": "^25.1.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.magicalcanvas.desktop",
    "productName": "Magical Canvas",
    "asar": false,
    "files": [
      "electron/**/*",
      "server/**/*",
      "dist/**/*",
      "config/**/*",
      "public/**/*",
      "build/icon.ico",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "electronDist": "node_modules/electron/dist",
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Magical Canvas",
      "artifactName": "MagicalCanvas-安装版.exe"
    },
    "portable": {
      "artifactName": "MagicalCanvas-便携版.exe"
    }
  }
}
